# Docker Compose에서 사용할 때 이 파일을 .env 로 복사한 뒤 값을 수정하세요.
# cp .env.example .env

# PostgreSQL
POSTGRES_DB=fms
POSTGRES_USER=fms_user
POSTGRES_PASSWORD=fms_password

# 프론트엔드 (Vite) — 브라우저가 호출할 백엔드 URL (로컬 Docker: 호스트에서 접근 시 localhost)
VITE_API_BASE_URL=http://localhost:5000

# MinIO / S3 (compose 기본값과 맞추면 추가 설정 불필요)
# S3_BUCKET_NAME=fms-bucket
# S3_REGION=ap-northeast-2

# 프로덕션(AWS S3 직접 연결) 예시 — EC2 IAM Role 사용 시 액세스 키는 비워 두고
# 엔드포인트를 비우면 AWS 기본 S3 엔드포인트를 씁니다.
# S3_ENDPOINT_URL=
# S3_USE_SSL=true
